#!/usr/bin/env bash
set -euo pipefail

FAST_CPUS="2,14"
SLOW_CPUS="6-8,18-20"
ALL_RESEARCH_CPUS="2,6-8,14,18-20"
PARTITION="/sys/fs/cgroup/research.partition"

usage() {
    cat <<'EOF'
Usage: corelab-on {fast|slow|all}

Modes:
  fast    Reserve only the fast benchmark core   (CPUs 2,14)
  slow    Reserve only the slow research cores   (CPUs 6-8,18-20)
  all     Reserve both the fast and slow cores

Creates an isolated cpuset partition so those CPUs are exclusively
available to research tasks and cannot be used by any other process.
EOF
}

if [[ "${EUID}" -ne 0 ]]; then
    echo "Error: run as root." >&2
    exit 1
fi

if [[ $# -ne 1 ]]; then
    usage >&2
    exit 1
fi

case "$1" in
    fast)  RESEARCH_CPUS="${FAST_CPUS}" ;;
    slow)  RESEARCH_CPUS="${SLOW_CPUS}" ;;
    all)  RESEARCH_CPUS="${ALL_RESEARCH_CPUS}" ;;
    -h|--help) usage; exit 0 ;;
    *)
        echo "Error: invalid mode '$1'." >&2
        usage >&2
        exit 1
        ;;
esac

if [[ -d "${PARTITION}" ]]; then
    echo "Error: research partition already active. Run corelab-off first." >&2
    exit 1
fi

_on_err() {
    echo "[corelab-on] Error: cleaning up partial partition" >&2
    echo "member" > "${PARTITION}/cpuset.cpus.partition" 2>/dev/null || true
    rmdir "${PARTITION}" 2>/dev/null || true
}

trap _on_err ERR

echo "[corelab-on] Creating isolated cpuset partition: ${RESEARCH_CPUS}"

if ! grep -q cpuset /sys/fs/cgroup/cgroup.subtree_control; then
    echo "+cpuset" > /sys/fs/cgroup/cgroup.subtree_control
fi

mkdir "${PARTITION}"

echo "${RESEARCH_CPUS}" > "${PARTITION}/cpuset.cpus"
echo "0" > "${PARTITION}/cpuset.mems"
echo "isolated" > "${PARTITION}/cpuset.cpus.partition"

echo "[corelab-on] Setting performance governor and disabling boost"

cpupower frequency-set -g performance > /dev/null

echo 0 > /sys/devices/system/cpu/cpufreq/boost

echo "[corelab-on] Done"
